						"method": "PUT",
						"url": {
							"raw": "{{baseUrl}}/api/wallets/{{walletId}}/transactions/{{transactionId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "wallets", "{{walletId}}", "transactions", "{{transactionId}}"]
						},
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
