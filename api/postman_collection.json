		{
			"name": "Import",
			"item": [
				{
					"name": "Bulk Import Transactions",
					"request": {
						"method": "POST",
						"url": {
							"raw": "{{baseUrl}}/api/wallets/{{walletId}}/import",
							"host": ["{{baseUrl}}"],
							"path": ["api", "wallets", "{{walletId}}", "import"]
						},
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"transactions\": [\n    {\n      \"date\": \"2026-03-04T05:00:00Z\",\n      \"type\": \"Expense\",\n      \"categoryName\": \"Food & Drink\",\n      \"amount\": -72770.54,\n      \"currencyCode\": \"IDR\",\n      \"description\": \"Lei cha\"\n    },\n    {\n      \"date\": \"2026-03-05T08:00:00Z\",\n      \"type\": \"Income\",\n      \"categoryName\": \"Gunpla\",\n      \"amount\": 1023854.4,\n      \"currencyCode\": \"IDR\",\n      \"description\": \"Eternal star glory stargazer\"\n    }\n  ]\n}"
						},
						"description": "Bulk import from Spendee or similar. Negative amounts auto-converted to positive. Unknown categories auto-created as wallet-scoped. Spendee aliases: 'Food & Drink' → 'Food & Dining', 'Utilities' → 'Bills & Utilities'. Max 1000 per batch."
					}
				},
				{
					"name": "Bulk Import (Spendee Full Batch)",
					"request": {
						"method": "POST",
						"url": {
							"raw": "{{baseUrl}}/api/wallets/{{walletId}}/import",
							"host": ["{{baseUrl}}"],
							"path": ["api", "wallets", "{{walletId}}", "import"]
						},
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
