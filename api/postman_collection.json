{
	"info": {
		"name": "My Wallet API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"description": "Spending Tracker API — Neon + Cloudflare Workers"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8787",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		},
		{
			"key": "walletId",
			"value": "1",
			"type": "string"
		},
		{
			"key": "transactionId",
			"value": "1",
			"type": "string"
		},
		{
			"key": "categoryId",
			"value": "1",
			"type": "string"
		},
		{
			"key": "recurringId",
			"value": "1",
			"type": "string"
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Check Username Availability",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/auth/check-username?username=johndoe",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "check-username"],
							"query": [
								{ "key": "username", "value": "johndoe" }
							]
						}
					}
				},
				{
					"name": "Register",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"url": {
							"raw": "{{baseUrl}}/api/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "register"]
						},
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"username\": \"johndoe\"\n}"
						}
					}
				},
				{
					"name": "Verify Registration",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var json = pm.response.json();",
									"if (json.token) {",
									"    pm.collectionVariables.set('token', json.token);",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"url": {
							"raw": "{{baseUrl}}/api/auth/verify-registration",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "verify-registration"]
						},
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"johndoe\",\n  \"otp\": \"123456\"\n}"
						}
					}
				},
				{
					"name": "Login",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "login"]
						},
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"johndoe\"\n}"
						}
					}
				},
				{
					"name": "Verify Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var json = pm.response.json();",
									"if (json.token) {",
									"    pm.collectionVariables.set('token', json.token);",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"url": {
							"raw": "{{baseUrl}}/api/auth/verify-login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "verify-login"]
						},
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"johndoe\",\n  \"otp\": \"123456\"\n}"
						}
					}
				},
				{
					"name": "Resend OTP",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"url": {
							"raw": "{{baseUrl}}/api/auth/resend-otp",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "resend-otp"]
						},
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"johndoe\",\n  \"purpose\": \"login\"\n}"
						}
					},
					"description": "Resend OTP with 60-second cooldown. Invalidates previous unused OTPs. Purpose must be 'login' or 'register'."
				}
			]
		},
		{
			"name": "Users",
			"item": [
				{
					"name": "Get My Profile",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/users/me",
							"host": ["{{baseUrl}}"],
							"path": ["api", "users", "me"]
						}
					}
				},
				{
					"name": "Search User by Username",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/users/search?username=johndoe",
							"host": ["{{baseUrl}}"],
							"path": ["api", "users", "search"],
							"query": [
								{ "key": "username", "value": "johndoe" }
							]
						}
					}
				}
			]
		},
		{
			"name": "Exchange Rates",
			"item": [
				{
					"name": "Fetch Rates",
					"request": {
						"method": "POST",
						"url": {
							"raw": "{{baseUrl}}/api/rates/fetch",
							"host": ["{{baseUrl}}"],
							"path": ["api", "rates", "fetch"]
						}
					}
				},
				{
					"name": "Get Recommendations",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/rates/recommendations",
							"host": ["{{baseUrl}}"],
							"path": ["api", "rates", "recommendations"]
