				},
				{
					"name": "Get Current Rate",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/rates/current?from=USD&to=SGD",
							"host": ["{{baseUrl}}"],
							"path": ["api", "rates", "current"],
							"query": [
								{ "key": "from", "value": "USD" },
								{ "key": "to", "value": "SGD" }
							]
						}
					}
				},
				{
					"name": "Add Manual Rate",
					"request": {
						"method": "POST",
						"url": {
							"raw": "{{baseUrl}}/api/rates/manual",
							"host": ["{{baseUrl}}"],
							"path": ["api", "rates", "manual"]
						},
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"fromCurrency\": \"USD\",\n  \"toCurrency\": \"SGD\",\n  \"rate\": 1.35,\n  \"notes\": \"Bank rate\"\n}"
						}
					}
				},
				{
					"name": "Apply Rate Recommendation",
					"request": {
						"method": "POST",
						"url": {
							"raw": "{{baseUrl}}/api/rates/apply",
							"host": ["{{baseUrl}}"],
							"path": ["api", "rates", "apply"]
						},
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"recommendationId\": 1,\n  \"notes\": \"Accepted daily rate\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "Categories",
			"item": [
				{
					"name": "List Categories",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/categories?walletId={{walletId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "categories"],
							"query": [
								{ "key": "walletId", "value": "{{walletId}}", "description": "Optional — omit for global categories only" }
							]
						}
					}
				},
				{
					"name": "Create Custom Category",
					"request": {
						"method": "POST",
						"url": {
							"raw": "{{baseUrl}}/api/categories",
							"host": ["{{baseUrl}}"],
							"path": ["api", "categories"]
						},
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Groceries\",\n  \"icon\": \"cart\",\n  \"color\": \"#4CAF50\",\n  \"walletId\": 1\n}"
						}
					}
				},
				{
					"name": "Edit Category",
					"request": {
						"method": "PUT",
						"url": {
							"raw": "{{baseUrl}}/api/categories/{{categoryId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "categories", "{{categoryId}}"]
						},
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Groceries & Supermarket\",\n  \"icon\": \"shopping-cart\",\n  \"color\": \"#388E3C\"\n}"
						}
					}
				},
				{
					"name": "Delete Category",
					"request": {
						"method": "DELETE",
						"url": {
							"raw": "{{baseUrl}}/api/categories/{{categoryId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "categories", "{{categoryId}}"]
						}
					}
				}
			]
		},
