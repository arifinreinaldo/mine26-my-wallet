		{
			"name": "Transactions",
			"item": [
				{
					"name": "Add Transaction",
					"request": {
						"method": "POST",
						"url": {
							"raw": "{{baseUrl}}/api/wallets/{{walletId}}/transactions",
							"host": ["{{baseUrl}}"],
							"path": ["api", "wallets", "{{walletId}}", "transactions"]
						},
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"date\": \"2025-02-01\",\n  \"description\": \"Team lunch\",\n  \"amount\": 45.00,\n  \"type\": \"expense\",\n  \"currencyCode\": \"SGD\",\n  \"categoryId\": 1,\n  \"paymentMethod\": \"Credit Card\"\n}"
						}
					}
				},
				{
					"name": "List Transactions",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/wallets/{{walletId}}/transactions",
							"host": ["{{baseUrl}}"],
							"path": ["api", "wallets", "{{walletId}}", "transactions"],
							"query": [
								{ "key": "from", "value": "2025-01-01", "disabled": true },
								{ "key": "to", "value": "2025-12-31", "disabled": true },
								{ "key": "createdBy", "value": "1", "disabled": true },
								{ "key": "categoryId", "value": "1", "disabled": true },
								{ "key": "type", "value": "expense", "disabled": true },
								{ "key": "q", "value": "lunch", "description": "Free-text search on description and notes", "disabled": true },
								{ "key": "page", "value": "1", "description": "Page number (default 1)", "disabled": true },
								{ "key": "limit", "value": "50", "description": "Results per page (default 50, max 200)", "disabled": true }
							]
						}
					}
				},
				{
					"name": "Edit Transaction",
