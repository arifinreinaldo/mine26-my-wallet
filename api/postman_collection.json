		{
			"name": "Dashboard",
			"item": [
				{
					"name": "Get Wallet Dashboard",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/wallets/{{walletId}}/dashboard",
							"host": ["{{baseUrl}}"],
							"path": ["api", "wallets", "{{walletId}}", "dashboard"]
						},
						"description": "Single-call wallet summary: today/week/month spending, income, top categories, recent transactions, current balance. All amounts converted to wallet default currency."
					}
				}
			]
		},
		{
			"name": "Reports",
			"item": [
				{
					"name": "Get Spending Report",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/wallets/{{walletId}}/reports/spending?currency=SGD",
							"host": ["{{baseUrl}}"],
							"path": ["api", "wallets", "{{walletId}}", "reports", "spending"],
							"query": [
								{ "key": "currency", "value": "SGD", "description": "Target currency for conversion (default SGD)" },
								{ "key": "from", "value": "2025-01-01", "disabled": true },
								{ "key": "to", "value": "2025-12-31", "disabled": true },
								{ "key": "page", "value": "1", "description": "Page number for transaction list (default 1)", "disabled": true },
								{ "key": "limit", "value": "50", "description": "Results per page (default 50, max 200). Summary always covers all data.", "disabled": true }
							]
						},
						"description": "Summary (income/expense/category/monthly/user totals) always covers ALL matching transactions. Transaction detail list is paginated."
					}
				}
			]
		},
